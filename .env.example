# ─── ZBOT Configuration ───────────────────────────────────────────────────────
# Copy to .env and fill in your values.

# ─── LLM BACKEND (pick one) ──────────────────────────────────────────────────

# Option 1: Any OpenAI-compatible API (Ollama, Together, Groq, vLLM, LM Studio)
ZBOT_LLM_BASE_URL=http://localhost:11434/v1   # Ollama default
ZBOT_LLM_MODEL=llama3.1:8b                    # any model your provider supports
ZBOT_LLM_API_KEY=ollama                        # "ollama" for local, real key for hosted

# Option 2: Anthropic Claude (comment out the above, uncomment below)
# ZBOT_ANTHROPIC_API_KEY=sk-ant-...

# ─── POPULAR PROVIDER EXAMPLES ───────────────────────────────────────────────
#
# Ollama (local, free):
#   ZBOT_LLM_BASE_URL=http://localhost:11434/v1
#   ZBOT_LLM_MODEL=llama3.1:8b
#   ZBOT_LLM_API_KEY=ollama
#
# Together AI ($0.20/M tokens):
#   ZBOT_LLM_BASE_URL=https://api.together.xyz/v1
#   ZBOT_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   ZBOT_LLM_API_KEY=tgp_v1_...
#
# Groq (fast, free tier):
#   ZBOT_LLM_BASE_URL=https://api.groq.com/openai/v1
#   ZBOT_LLM_MODEL=llama-3.1-70b-versatile
#   ZBOT_LLM_API_KEY=gsk_...
#
# OpenRouter (100+ models, one key):
#   ZBOT_LLM_BASE_URL=https://openrouter.ai/api/v1
#   ZBOT_LLM_MODEL=google/gemini-2.5-flash
#   ZBOT_LLM_API_KEY=sk-or-...
#
# LM Studio (local GUI):
#   ZBOT_LLM_BASE_URL=http://localhost:1234/v1
#   ZBOT_LLM_MODEL=local-model
#   ZBOT_LLM_API_KEY=lm-studio

# ─── TOOLS (optional) ────────────────────────────────────────────────────────
# ZBOT_BRAVE_API_KEY=              # Brave Search API key for web_search tool
# ZBOT_OPENAI_API_KEY=             # OpenAI key for planner/critic (optional)

# ─── DATABASE (optional — enables memory persistence, audit log, workflows) ──
# ZBOT_DATABASE_URL=postgresql://user:pass@localhost:5432/zbot?sslmode=disable
# Or individual fields:
# ZBOT_DB_HOST=localhost
# ZBOT_DB_NAME=zbot
# ZBOT_DB_USER=zbot
# ZBOT_DB_PASSWORD=

# ─── CUSTOMIZATION ───────────────────────────────────────────────────────────
# ZBOT_SYSTEM_PROMPT=              # Custom system prompt (override default persona)
# ZBOT_ENV=production              # "production" binds to 0.0.0.0
# ZBOT_BIND_ALL=true               # Force bind to all interfaces

# ─── SLACK (optional — enables Slack bot gateway) ────────────────────────────
# ZBOT_SLACK_TOKEN=xoxb-...
# ZBOT_SLACK_APP_TOKEN=xapp-...

# ─── SEARCH PROVIDER (pick one — Serper is 16x cheaper than Brave) ───────
# ZBOT_SERPER_API_KEY=              # Serper.dev — Google results, $0.30/1K queries
# ZBOT_BRAVE_API_KEY=               # Brave Search — independent index, $5/1K queries

# ─── CHEAP MODEL STACK (pro performance, pickup game prices) ─────────────
#
# DeepSeek V3.2 via DeepInfra ($0.14/$0.28 per 1M tokens):
#   ZBOT_LLM_BASE_URL=https://api.deepinfra.com/v1/openai
#   ZBOT_LLM_MODEL=deepseek-ai/DeepSeek-V3-0324
#   ZBOT_LLM_API_KEY=your-deepinfra-key
#
# Combined with Serper ($0.30/1K):
#   Total cost per research question: ~$0.004 (vs $0.073 with Claude+Brave)


# ─── VAULT (encrypted secrets store) ─────────────────────────────────────
# Generate a master key: openssl rand -hex 32
# Without this, vault generates an ephemeral key that won't survive restarts.
# ZBOT_VAULT_MASTER_KEY=

# ─── DEEPINFRA (cheap cognitive stages — DeepSeek V3.2) ──────────────────
# Enables the Frontal Lobe (planning) and Thalamus (verification) stages.
# Without this, falls back to Haiku or primary model.
# ZBOT_DEEPINFRA_API_KEY=

# ─── OPENROUTER (multi-model access for deep research) ───────────────────
# Enables the 5-model deep research pipeline.
# ZBOT_OPENROUTER_API_KEY=

# ─── GHL (GoHighLevel CRM) ──────────────────────────────────────────────
# ZBOT_GHL_API_TOKEN=
# ZBOT_GHL_LOCATION_ID=

# ─── GITHUB ──────────────────────────────────────────────────────────────
# ZBOT_GITHUB_TOKEN=

# ─── GOOGLE SHEETS ───────────────────────────────────────────────────────
# ZBOT_GOOGLE_SHEETS_CREDENTIALS=   # JSON service account credentials

# ─── SMTP (email) ────────────────────────────────────────────────────────
# ZBOT_SMTP_HOST=
# ZBOT_SMTP_USER=
# ZBOT_SMTP_PASS=
# ZBOT_SMTP_FROM=
