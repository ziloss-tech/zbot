{
  "title": "ZBOT — Token Cost",
  "uid": "zbot-cost",
  "tags": ["zbot"],
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Estimated Cost Today (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "loki" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({app=\"zbot\"} | json | unwrap cost_usd [1d]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Input Tokens Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "loki" },
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(sum_over_time({app=\"zbot\"} | json | unwrap input_tokens [1d]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Output Tokens Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "loki" },
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(sum_over_time({app=\"zbot\"} | json | unwrap output_tokens [1d]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost Per Turn (last 24h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": { "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum_over_time({app=\"zbot\"} | json | msg=`agent turn complete` | unwrap cost_usd [5m])",
          "legendFormat": "cost per turn",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Most Expensive Workflows",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "loki" },
      "options": { "enableLogDetails": true, "showTime": true },
      "targets": [
        {
          "expr": "{app=\"zbot\"} | json | msg=`agent turn complete` | cost_usd != `` | line_format \"workflow={{.workflow_id}} task={{.task_id}} cost=${{.cost_usd}} tokens_in={{.input_tokens}} tokens_out={{.output_tokens}}\"",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
